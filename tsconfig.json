{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowSyntheticDefaultImports": true,
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "lib": [
            "ES2018",
            "DOM"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}